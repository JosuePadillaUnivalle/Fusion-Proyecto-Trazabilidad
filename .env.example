APP_NAME=AgroFusion
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001
# auto = detecta la IP WiFi al ejecutar php artisan serve (solo local)
SERVER_HOST=auto
SERVER_PORT=8001

# --- Railway / producción (configurar en el panel Variables) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://tu-servicio.up.railway.app
# DB_CONNECTION=pgsql
# DATABASE_URL=  (Railway la inyecta al vincular PostgreSQL)
# RUN_SEED=true  (opcional, solo primer deploy con BD vacía)
APP_TIMEZONE=America/La_Paz

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=1

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite local (incluido en el repo con datos demo)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_COOKIE=agrofusion-session
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@agrofusion.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Opcional: clima en panel
OPENWEATHER_API_KEY=
